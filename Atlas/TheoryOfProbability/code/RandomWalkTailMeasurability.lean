import Mathlib.Probability.Independence.ZeroOne
import Mathlib.Probability.IdentDistrib
import Mathlib.MeasureTheory.Measure.MeasureSpace
import Mathlib.Topology.Instances.EReal.Lemmas
import Mathlib.Topology.Algebra.Order.LiminfLimsup
import Atlas.TheoryOfProbability.code.TailSigmaAlgebra
import Atlas.TheoryOfProbability.code.RandomWalkDichotomy

set_option maxHeartbeats 4000000

open MeasureTheory ProbabilityTheory Filter Finset Topology MeasurableSpace

variable {Ω : Type*}

namespace RandomWalkTailMeasurability

/-- The natural filtration of σ-algebras `σ(Xₙ)` generated by a sequence `X : ℕ → Ω → ℝ`
of random variables, indexed by `n`. -/
abbrev sigmaAlg (X : ℕ → Ω → ℝ) : ℕ → MeasurableSpace Ω :=
  fun n => MeasurableSpace.comap (X n) inferInstance

/-- For `n ≤ i`, the random variable `Xᵢ` is measurable with respect to the σ-algebra
`σ(Xₙ, Xₙ₊₁, …)` (the tail σ-algebra starting from index `n`). -/
lemma meas_Xi (X : ℕ → Ω → ℝ) (n i : ℕ) (h : n ≤ i) :
    @Measurable _ _ (tailMeasurableSpaceFrom (sigmaAlg X) n) _ (X i) :=
  Measurable.of_comap_le (le_iSup₂
    (f := fun j (_ : n ≤ j) => MeasurableSpace.comap (X j) (inferInstance : MeasurableSpace ℝ)) i h)

/-- The tail partial sum `∑_{i ∈ [n, m)} Xᵢ` is measurable with respect to the σ-algebra
generated by `Xₙ, Xₙ₊₁, …`. -/
lemma meas_tSum (X : ℕ → Ω → ℝ) (n m : ℕ) :
    @Measurable _ _ (tailMeasurableSpaceFrom (sigmaAlg X) n) _ (fun ω => ∑ i ∈ Ico n m, X i ω) :=
  Finset.measurable_sum _ (fun i hi => meas_Xi X n i (mem_Ico.mp hi).1)

/-- The event `{Sₘ → +∞}` (the partial sums of a sequence drift to `+∞`) lies in the
tail σ-algebra starting from any index `n`, by expressing it as a countable Boolean
combination of events measurable with respect to `σ(Xₙ, Xₙ₊₁, …)`. -/
theorem measurableSet_driftsToTop_from (X : ℕ → Ω → ℝ) (n : ℕ) :
    @MeasurableSet _ (tailMeasurableSpaceFrom (sigmaAlg X) n)
      {ω | Tendsto (fun m => randomWalkPartialSum X m ω) atTop atTop} := by
  suffices h : {ω | Tendsto (fun m => randomWalkPartialSum X m ω) atTop atTop} =
    ⋂ (b : ℤ), ⋃ (N : ℕ), ⋂ (m : ℕ), ⋂ (_ : N ≤ m),
      {ω | (b : ℝ) ≤ ∑ i ∈ Ico n m, X i ω} by
    rw [h]; exact .iInter fun _ => .iUnion fun _ => .iInter fun m => .iInter fun _ =>
      (meas_tSum X n m) measurableSet_Ici
  ext ω; simp only [Set.mem_setOf_eq, Set.mem_iInter, Set.mem_iUnion, randomWalkPartialSum]
  constructor
  · intro h b
    rw [tendsto_atTop_atTop] at h
    obtain ⟨N, hN⟩ := h (b + ∑ i ∈ range n, X i ω)
    refine ⟨max N n, fun m hm => ?_⟩
    have hm_N := le_trans (le_max_left N n) hm
    have hm_n := le_trans (le_max_right N n) hm
    linarith [hN m hm_N, Finset.sum_range_add_sum_Ico (fun i => X i ω) hm_n]
  · intro h; rw [tendsto_atTop_atTop]; intro b
    obtain ⟨N, hN⟩ := h ⌈b - ∑ i ∈ range n, X i ω⌉
    refine ⟨max N n, fun m hm => ?_⟩
    have hm_N := le_trans (le_max_left N n) hm
    have hm_n := le_trans (le_max_right N n) hm
    have h1 : (⌈b - ∑ i ∈ range n, X i ω⌉ : ℝ) ≤ ∑ i ∈ Ico n m, X i ω :=
      by exact_mod_cast hN m hm_N
    linarith [Finset.sum_range_add_sum_Ico (fun i => X i ω) hm_n,
      Int.le_ceil (b - ∑ i ∈ range n, X i ω)]

/-- The event `{Sₘ → -∞}` is measurable with respect to `σ(Xₙ, Xₙ₊₁, …)` for every `n`. -/
theorem measurableSet_driftsToBot_from (X : ℕ → Ω → ℝ) (n : ℕ) :
    @MeasurableSet _ (tailMeasurableSpaceFrom (sigmaAlg X) n)
      {ω | Tendsto (fun m => randomWalkPartialSum X m ω) atTop atBot} := by
  suffices h : {ω | Tendsto (fun m => randomWalkPartialSum X m ω) atTop atBot} =
    ⋂ (b : ℤ), ⋃ (N : ℕ), ⋂ (m : ℕ), ⋂ (_ : N ≤ m),
      {ω | ∑ i ∈ Ico n m, X i ω ≤ (b : ℝ)} by
    rw [h]; exact .iInter fun _ => .iUnion fun _ => .iInter fun m => .iInter fun _ =>
      (meas_tSum X n m) measurableSet_Iic
  ext ω; simp only [Set.mem_setOf_eq, Set.mem_iInter, Set.mem_iUnion, randomWalkPartialSum]
  constructor
  · intro h b
    rw [tendsto_atTop_atBot] at h
    obtain ⟨N, hN⟩ := h (b + ∑ i ∈ range n, X i ω)
    refine ⟨max N n, fun m hm => ?_⟩
    have hm_N := le_trans (le_max_left N n) hm
    have hm_n := le_trans (le_max_right N n) hm
    linarith [hN m hm_N, Finset.sum_range_add_sum_Ico (fun i => X i ω) hm_n]
  · intro h; rw [tendsto_atTop_atBot]; intro b
    obtain ⟨N, hN⟩ := h ⌊b - ∑ i ∈ range n, X i ω⌋
    refine ⟨max N n, fun m hm => ?_⟩
    have hm_N := le_trans (le_max_left N n) hm
    have hm_n := le_trans (le_max_right N n) hm
    have h1 : ∑ i ∈ Ico n m, X i ω ≤ (⌊b - ∑ i ∈ range n, X i ω⌋ : ℝ) :=
      by exact_mod_cast hN m hm_N
    linarith [Finset.sum_range_add_sum_Ico (fun i => X i ω) hm_n,
      Int.floor_le (b - ∑ i ∈ range n, X i ω)]

/-- The event `{limsup Sₘ = +∞}` is measurable with respect to `σ(Xₙ, Xₙ₊₁, …)` for
every `n`. -/
theorem measurableSet_limsupTop_from (X : ℕ → Ω → ℝ) (n : ℕ) :
    @MeasurableSet _ (tailMeasurableSpaceFrom (sigmaAlg X) n)
      {ω | limsup (fun m => ((randomWalkPartialSum X m ω : ℝ) : EReal)) atTop = ⊤} := by
  suffices h : {ω | limsup (fun m => ((randomWalkPartialSum X m ω : ℝ) : EReal)) atTop = ⊤} =
    ⋂ (b : ℤ), ⋂ (N : ℕ), ⋃ (m : ℕ), ⋃ (_ : N ≤ m),
      {ω | (b : ℝ) < ∑ i ∈ Ico n m, X i ω} by
    rw [h]; exact .iInter fun _ => .iInter fun _ => .iUnion fun m => .iUnion fun _ =>
      (meas_tSum X n m) measurableSet_Ioi
  ext ω; simp only [Set.mem_setOf_eq, Set.mem_iInter, Set.mem_iUnion, randomWalkPartialSum]
  set Sn := ∑ i ∈ range n, X i ω
  constructor
  · intro h b N
    have hfreq := Filter.frequently_lt_of_lt_limsup ⟨⊥, fun _ _ => bot_le⟩
      (h ▸ EReal.coe_lt_top ((b : ℝ) + Sn))
    rw [frequently_atTop] at hfreq
    obtain ⟨m, hm, hlt⟩ := hfreq (max N n)
    refine ⟨m, le_trans (le_max_left _ _) hm, ?_⟩
    have hm_n := le_trans (le_max_right N n) hm
    rw [EReal.coe_lt_coe_iff] at hlt
    linarith [Finset.sum_range_add_sum_Ico (fun i => X i ω) hm_n]
  · intro h
    have hall : ∀ r : ℝ, (r : EReal) ≤
        limsup (fun m => ((∑ i ∈ range m, X i ω : ℝ) : EReal)) atTop := by
      intro r
      apply Filter.le_limsup_of_frequently_le'
      rw [frequently_atTop]; intro N
      obtain ⟨m, hm, hlt⟩ := h ⌈r - Sn⌉ (max N n)
      refine ⟨m, le_trans (le_max_left _ _) hm, ?_⟩
      have hm_n := le_trans (le_max_right N n) hm
      rw [EReal.coe_le_coe_iff]
      linarith [Finset.sum_range_add_sum_Ico (fun i => X i ω) hm_n,
        Int.le_ceil (r - Sn)]
    by_contra hne
    have hne_bot : limsup (fun m => ((∑ i ∈ range m, X i ω : ℝ) : EReal)) atTop ≠ ⊥ := by
      intro heq; exact absurd (heq ▸ hall 0) (not_le.mpr (EReal.bot_lt_coe 0))
    set L := limsup (fun m => ((∑ i ∈ range m, X i ω : ℝ) : EReal)) atTop with hL_def
    have hL_ne_top : L ≠ ⊤ := hne
    have hL_ne_bot : L ≠ ⊥ := hne_bot
    lift L to ℝ using ⟨hL_ne_top, hL_ne_bot⟩ with r hr
    exact absurd (hr ▸ hall (r + 1)) (not_le.mpr (hr ▸ EReal.coe_lt_coe_iff.mpr (lt_add_one r)))

/-- The event `{liminf Sₘ = -∞}` is measurable with respect to `σ(Xₙ, Xₙ₊₁, …)` for
every `n`. -/
theorem measurableSet_liminfBot_from (X : ℕ → Ω → ℝ) (n : ℕ) :
    @MeasurableSet _ (tailMeasurableSpaceFrom (sigmaAlg X) n)
      {ω | liminf (fun m => ((randomWalkPartialSum X m ω : ℝ) : EReal)) atTop = ⊥} := by
  suffices h : {ω | liminf (fun m => ((randomWalkPartialSum X m ω : ℝ) : EReal)) atTop = ⊥} =
    ⋂ (b : ℤ), ⋂ (N : ℕ), ⋃ (m : ℕ), ⋃ (_ : N ≤ m),
      {ω | ∑ i ∈ Ico n m, X i ω < (b : ℝ)} by
    rw [h]; exact .iInter fun _ => .iInter fun _ => .iUnion fun m => .iUnion fun _ =>
      (meas_tSum X n m) measurableSet_Iio
  ext ω; simp only [Set.mem_setOf_eq, Set.mem_iInter, Set.mem_iUnion, randomWalkPartialSum]
  set Sn := ∑ i ∈ range n, X i ω
  constructor
  · intro h b N
    have hfreq := Filter.frequently_lt_of_liminf_lt ⟨⊤, fun _ _ => le_top⟩
      (h ▸ EReal.bot_lt_coe ((b : ℝ) + Sn))
    rw [frequently_atTop] at hfreq
    obtain ⟨m, hm, hlt⟩ := hfreq (max N n)
    refine ⟨m, le_trans (le_max_left _ _) hm, ?_⟩
    have hm_n := le_trans (le_max_right N n) hm
    rw [EReal.coe_lt_coe_iff] at hlt
    linarith [Finset.sum_range_add_sum_Ico (fun i => X i ω) hm_n]
  · intro h
    have hall : ∀ r : ℝ, liminf (fun m => ((∑ i ∈ range m, X i ω : ℝ) : EReal)) atTop ≤
        (r : EReal) := by
      intro r
      apply Filter.liminf_le_of_frequently_le'
      rw [frequently_atTop]; intro N
      obtain ⟨m, hm, hlt⟩ := h ⌊r - Sn⌋ (max N n)
      refine ⟨m, le_trans (le_max_left _ _) hm, ?_⟩
      have hm_n := le_trans (le_max_right N n) hm
      rw [EReal.coe_le_coe_iff]
      linarith [Finset.sum_range_add_sum_Ico (fun i => X i ω) hm_n,
        Int.floor_le (r - Sn)]
    by_contra hne
    have hne_top : liminf (fun m => ((∑ i ∈ range m, X i ω : ℝ) : EReal)) atTop ≠ ⊤ := by
      intro heq; exact absurd (heq ▸ hall 0) (not_le.mpr (EReal.coe_lt_top 0))
    set L := liminf (fun m => ((∑ i ∈ range m, X i ω : ℝ) : EReal)) atTop with hL_def
    have hL_ne_top : L ≠ ⊤ := hne_top
    have hL_ne_bot : L ≠ ⊥ := hne
    lift L to ℝ using ⟨hL_ne_top, hL_ne_bot⟩ with r hr
    exact absurd (hr ▸ hall (r - 1)) (not_le.mpr (hr ▸ EReal.coe_lt_coe_iff.mpr (sub_one_lt r)))

/-- The event `{Sₘ converges to a finite limit}` is measurable with respect to
`σ(Xₙ, Xₙ₊₁, …)` for every `n`. The proof rewrites convergence as a Cauchy condition
expressed via tail partial sums. -/
theorem measurableSet_convergesFinite_from (X : ℕ → Ω → ℝ) (n : ℕ) :
    @MeasurableSet _ (tailMeasurableSpaceFrom (sigmaAlg X) n)
      {ω | ∃ l : ℝ, Tendsto (fun m => randomWalkPartialSum X m ω) atTop (𝓝 l)} := by


  suffices h : {ω | ∃ l : ℝ, Tendsto (fun m => randomWalkPartialSum X m ω) atTop (𝓝 l)} =
    ⋂ (k : ℕ), ⋃ (N : ℕ), ⋂ (m₁ : ℕ), ⋂ (_ : N ≤ m₁), ⋂ (m₂ : ℕ), ⋂ (_ : N ≤ m₂),
      {ω | |∑ i ∈ Ico n m₁, X i ω - ∑ i ∈ Ico n m₂, X i ω| < 1 / ((k : ℝ) + 1)} by
    rw [h]
    apply MeasurableSet.iInter; intro k; apply MeasurableSet.iUnion; intro N
    apply MeasurableSet.iInter; intro m₁; apply MeasurableSet.iInter; intro _
    apply MeasurableSet.iInter; intro m₂; apply MeasurableSet.iInter; intro _
    have : {ω | |∑ i ∈ Ico n m₁, X i ω - ∑ i ∈ Ico n m₂, X i ω| < 1 / ((k : ℝ) + 1)} =
        (fun ω => ∑ i ∈ Ico n m₁, X i ω - ∑ i ∈ Ico n m₂, X i ω) ⁻¹'
          Set.Ioo (-(1 / ((k : ℝ) + 1))) (1 / ((k : ℝ) + 1)) := by
      ext ω; simp only [Set.mem_setOf_eq, Set.mem_preimage, Set.mem_Ioo, abs_lt]
    rw [this]; exact ((meas_tSum X n m₁).sub (meas_tSum X n m₂)) measurableSet_Ioo

  ext ω; simp only [Set.mem_setOf_eq, Set.mem_iInter, Set.mem_iUnion, randomWalkPartialSum]
  have diff_eq : ∀ m₁ m₂, n ≤ m₁ → n ≤ m₂ →
      (∑ i ∈ range m₁, X i ω) - (∑ i ∈ range m₂, X i ω) =
      (∑ i ∈ Ico n m₁, X i ω) - (∑ i ∈ Ico n m₂, X i ω) := fun m₁ m₂ h₁ h₂ => by
    linarith [Finset.sum_range_add_sum_Ico (fun i => X i ω) h₁,
      Finset.sum_range_add_sum_Ico (fun i => X i ω) h₂]
  constructor
  · intro ⟨l, hl⟩ k
    rw [Metric.tendsto_atTop] at hl
    obtain ⟨N, hN⟩ := hl (1 / ((k : ℝ) + 1) / 2) (by positivity)
    refine ⟨max N n, fun m₁ hm₁ m₂ hm₂ => ?_⟩
    have hm₁_N := le_trans (le_max_left N n) hm₁
    have hm₁_n := le_trans (le_max_right N n) hm₁
    have hm₂_N := le_trans (le_max_left N n) hm₂
    have hm₂_n := le_trans (le_max_right N n) hm₂
    rw [← diff_eq m₁ m₂ hm₁_n hm₂_n]
    have h1 := hN m₁ hm₁_N; rw [Real.dist_eq] at h1
    have h2 := hN m₂ hm₂_N; rw [Real.dist_eq] at h2
    have hab : |∑ i ∈ range m₁, X i ω - ∑ i ∈ range m₂, X i ω| ≤
        |∑ i ∈ range m₁, X i ω - l| + |l - ∑ i ∈ range m₂, X i ω| := by
      calc |∑ i ∈ range m₁, X i ω - ∑ i ∈ range m₂, X i ω|
          = |(∑ i ∈ range m₁, X i ω - l) + (l - ∑ i ∈ range m₂, X i ω)| := by ring_nf
        _ ≤ _ := abs_add_le (∑ i ∈ range m₁, X i ω - l) (l - ∑ i ∈ range m₂, X i ω)
    have h3 := abs_nonneg (∑ i ∈ range m₁, X i ω - l)
    have h4 := abs_nonneg (l - ∑ i ∈ range m₂, X i ω)
    have h5 : |l - ∑ i ∈ range m₂, X i ω| = |∑ i ∈ range m₂, X i ω - l| := abs_sub_comm _ _
    linarith

  · intro h
    have hcauchy : CauchySeq (fun m => ∑ i ∈ range m, X i ω) := by
      rw [Metric.cauchySeq_iff]; intro ε hε
      obtain ⟨k, hk⟩ := exists_nat_gt (1 / ε)
      have hk_pos : (0 : ℝ) < (k : ℝ) + 1 := by positivity
      obtain ⟨N, hN⟩ := h k
      refine ⟨max N n, fun m₁ hm₁ m₂ hm₂ => ?_⟩
      rw [Real.dist_eq, diff_eq m₁ m₂ (le_trans (le_max_right _ _) hm₁)
        (le_trans (le_max_right _ _) hm₂)]
      have := hN m₁ (le_trans (le_max_left _ _) hm₁) m₂ (le_trans (le_max_left _ _) hm₂)
      have h1 : (1 : ℝ) / ε < (k : ℝ) + 1 := by linarith
      have h_eps : 1 / ((k : ℝ) + 1) < ε :=
        (div_lt_iff₀ hk_pos).mpr (by nlinarith [div_lt_iff₀ hε |>.mp h1])
      linarith

    exact cauchySeq_tendsto_of_complete hcauchy

/-- The event `{Sₘ → +∞}` belongs to the tail σ-algebra of the sequence `X`. -/
theorem measurableSet_driftsToTop (X : ℕ → Ω → ℝ) :
    @MeasurableSet _ (tailMeasurableSpaceOfFun X)
      {ω | Tendsto (fun m => randomWalkPartialSum X m ω) atTop atTop} :=
  measurableSet_iInf.mpr fun n => measurableSet_driftsToTop_from X n

/-- The event `{Sₘ → -∞}` belongs to the tail σ-algebra of the sequence `X`. -/
theorem measurableSet_driftsToBot (X : ℕ → Ω → ℝ) :
    @MeasurableSet _ (tailMeasurableSpaceOfFun X)
      {ω | Tendsto (fun m => randomWalkPartialSum X m ω) atTop atBot} :=
  measurableSet_iInf.mpr fun n => measurableSet_driftsToBot_from X n

/-- The oscillation event `{limsup Sₘ = +∞ ∧ liminf Sₘ = -∞}` belongs to the tail
σ-algebra of the sequence `X`. -/
theorem measurableSet_oscillates (X : ℕ → Ω → ℝ) :
    @MeasurableSet _ (tailMeasurableSpaceOfFun X)
      {ω | limsup (fun m => ((randomWalkPartialSum X m ω : ℝ) : EReal)) atTop = ⊤ ∧
           liminf (fun m => ((randomWalkPartialSum X m ω : ℝ) : EReal)) atTop = ⊥} :=
  measurableSet_iInf.mpr fun n =>
    (measurableSet_limsupTop_from X n).inter (measurableSet_liminfBot_from X n)

/-- The event `{Sₘ converges to a finite limit}` belongs to the tail σ-algebra
of the sequence `X`. -/
theorem measurableSet_convergesFinite (X : ℕ → Ω → ℝ) :
    @MeasurableSet _ (tailMeasurableSpaceOfFun X)
      {ω | ∃ l : ℝ, Tendsto (fun m => randomWalkPartialSum X m ω) atTop (𝓝 l)} :=
  measurableSet_iInf.mpr fun n => measurableSet_convergesFinite_from X n

end RandomWalkTailMeasurability
