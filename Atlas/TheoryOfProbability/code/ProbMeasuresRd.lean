/-- The vertex of the rectangle `[a, b] ‚äÜ ‚ĄĚŠĶą` obtained by selecting the lower coordinate
`a i` for indices `i ‚ąą S` and the upper coordinate `b i` otherwise. Used to compute
inclusion‚Äďexclusion sums over all `2^d` vertices. -/
def rectangleVertex {d : ‚Ąē} (a b : Fin d ‚Üí ‚ĄĚ) (S : Finset (Fin d)) : Fin d ‚Üí ‚ĄĚ :=
  fun i => if i ‚ąą S then a i else b i

/-- The alternating sum of `F` over the `2^d` vertices of the rectangle `(a, b]`. For a
distribution function `F` on `‚ĄĚŠĶą`, this equals the mass `őľ((a, b])` of the associated
measure (signed inclusion‚Äďexclusion). -/
def rectangleValue {d : ‚Ąē} (F : (Fin d ‚Üí ‚ĄĚ) ‚Üí ‚ĄĚ) (a b : Fin d ‚Üí ‚ĄĚ) : ‚ĄĚ :=
  ‚ąĎ S ‚ąą Finset.univ.powerset, (-1 : ‚ĄĚ) ^ S.card * F (rectangleVertex a b S)

/-- `F : ‚ĄĚŠĶą ‚Üí ‚ĄĚ` is coordinate-wise non-decreasing: for every coordinate `i`, fixing the
remaining coordinates and increasing the `i`-th argument does not decrease the value of `F`. -/
def IsCoordNonDecreasing {d : ‚Ąē} (F : (Fin d ‚Üí ‚ĄĚ) ‚Üí ‚ĄĚ) : Prop :=
  ‚ąÄ (i : Fin d) (x : Fin d ‚Üí ‚ĄĚ) (y z : ‚ĄĚ), y ‚Č§ z ‚Üí
    F (Function.update x i y) ‚Č§ F (Function.update x i z)

/-- `F : ‚ĄĚŠĶą ‚Üí ‚ĄĚ` is coordinate-wise right continuous: in every coordinate `i`, with the
remaining coordinates fixed, `F` is right-continuous in the `i`-th argument. -/
def IsCoordRightContinuous {d : ‚Ąē} (F : (Fin d ‚Üí ‚ĄĚ) ‚Üí ‚ĄĚ) : Prop :=
  ‚ąÄ (i : Fin d) (x : Fin d ‚Üí ‚ĄĚ),
    Filter.Tendsto (fun t => F (Function.update x i t))
      (nhdsWithin (x i) (Ici (x i))) (nhds (F x))

/-- `F` assigns a non-negative inclusion‚Äďexclusion value to every rectangle `(a, b]`
with `a ‚Č§ b` coordinate-wise. This is the multivariate analogue of monotonicity of a CDF
and is needed for `F` to come from a measure. -/
def IsRectangleNonneg {d : ‚Ąē} (F : (Fin d ‚Üí ‚ĄĚ) ‚Üí ‚ĄĚ) : Prop :=
  ‚ąÄ (a b : Fin d ‚Üí ‚ĄĚ), (‚ąÄ i, a i ‚Č§ b i) ‚Üí 0 ‚Č§ rectangleValue F a b

namespace MeasureTheory

/-- The family of left-infinite intervals `{Iic n : n ‚ąą ‚Ąē}` is a countable spanning
collection of `‚ĄĚ`: their union covers all of `‚ĄĚ`. -/
lemma Real.isCountablySpanning_range_Iic :
    IsCountablySpanning (range (Iic : ‚ĄĚ ‚Üí Set ‚ĄĚ)) :=
  ‚ü®fun n => Iic (n : ‚ĄĚ), fun n => mem_range.mpr ‚ü®n, rfl‚ü©, by
    ext x; simp only [Set.mem_iUnion, Set.mem_Iic, Set.mem_univ, iff_true]
    exact ‚ü®‚Ćąx‚ĆČ‚āä, Nat.le_ceil x‚ü©‚ü©

/-- The Borel `ŌÉ`-algebra on `‚ĄĚ` is generated by the left-infinite intervals `Iic x` for
`x ‚ąą ‚ĄĚ`. -/
lemma Real.generateFrom_range_Iic :
    generateFrom (range (Iic : ‚ĄĚ ‚Üí Set ‚ĄĚ)) = (inferInstance : MeasurableSpace ‚ĄĚ) :=
  (borel_eq_generateFrom_Iic ‚ĄĚ).symm.trans BorelSpace.measurable_eq.symm

/-- The collection of `d`-dimensional boxes of the form `‚ąŹŠĶĘ Iic (aŠĶĘ)` is a ŌÄ-system in
`‚ĄĚŠĶą`: finite intersections of such boxes are again of this form. -/
lemma isPiSystem_piIic (d : ‚Ąē) :
    IsPiSystem (univ.pi '' univ.pi (fun _ : Fin d => range (Iic : ‚ĄĚ ‚Üí Set ‚ĄĚ))) :=
  IsPiSystem.pi fun _ => isPiSystem_Iic

/-- The Borel `ŌÉ`-algebra on `‚ĄĚŠĶą` is generated by `d`-dimensional boxes of the form
`‚ąŹŠĶĘ Iic (aŠĶĘ)`. -/
lemma generateFrom_piIic (d : ‚Ąē) :
    generateFrom (univ.pi '' univ.pi (fun _ : Fin d => range (Iic : ‚ĄĚ ‚Üí Set ‚ĄĚ))) =
      (inferInstance : MeasurableSpace (Fin d ‚Üí ‚ĄĚ)) :=
  generateFrom_eq_pi
    (fun _ => Real.generateFrom_range_Iic)
    (fun _ => Real.isCountablySpanning_range_Iic)

/-- Two probability measures on `‚ĄĚŠĶą` are equal whenever they agree on all left-closed
quadrants `Iic a = {x | x ‚Č§ a}` for `a ‚ąą ‚ĄĚŠĶą`. This is the multivariate analogue of CDF
determining a probability measure. -/
theorem ProbabilityMeasure.ext_of_Iic (d : ‚Ąē)
    (őľ őĹ : Measure (Fin d ‚Üí ‚ĄĚ))
    [IsProbabilityMeasure őľ] [IsProbabilityMeasure őĹ]
    (h : ‚ąÄ a : Fin d ‚Üí ‚ĄĚ, őľ (Iic a) = őĹ (Iic a)) :
    őľ = őĹ := by
  apply ext_of_generate_finite
    (univ.pi '' univ.pi (fun _ : Fin d => range (Iic : ‚ĄĚ ‚Üí Set ‚ĄĚ)))
  ¬∑
    exact (generateFrom_piIic d).symm
  ¬∑
    exact isPiSystem_piIic d
  ¬∑
    intro s hs
    obtain ‚ü®f, hf, rfl‚ü© := hs
    choose a ha using fun i => hf i (Set.mem_univ i)
    have : univ.pi f = Iic a := by
      ext x; simp only [Set.mem_pi, Set.mem_univ, true_implies, Set.mem_Iic, Pi.le_def]
      exact forall_congr' fun i => by rw [‚Üź ha i]; simp [Set.mem_Iic]
    rw [this]; exact h a
  ¬∑
    simp [measure_univ]

end MeasureTheory

/-- **Existence (Carath√©odory extension)**. Given `F : ‚ĄĚŠĶą ‚Üí ‚ĄĚ` that is coordinate-wise
non-decreasing, coordinate-wise right-continuous, and assigns non-negative rectangle values,
there exists a Borel measure `őľ` on `‚ĄĚŠĶą` whose mass on each rectangle `(a, b]` equals
`rectangleValue F a b`. -/
theorem caratheodory_extension_rectangleFunction {d : ‚Ąē}
    (F : (Fin d ‚Üí ‚ĄĚ) ‚Üí ‚ĄĚ)
    (hF_mono : IsCoordNonDecreasing F)
    (hF_rcont : IsCoordRightContinuous F)
    (hF_rect : IsRectangleNonneg F) :
    ‚ąÉ őľ : MeasureTheory.Measure (Fin d ‚Üí ‚ĄĚ),
      ‚ąÄ (a b : Fin d ‚Üí ‚ĄĚ), (‚ąÄ i, a i ‚Č§ b i) ‚Üí
        őľ (Set.univ.pi fun i => Set.Ioc (a i) (b i)) =
          ENNReal.ofReal (rectangleValue F a b) := by sorry

/-- The collection of nonempty bounded half-open intervals `(l, u]` in `‚ĄĚ`. Used as a
generating ŌÄ-system for the Borel ŌÉ-algebra. -/
def C_Ioc_pi : Set (Set ‚ĄĚ) := { S | ‚ąÉ l u, l < u ‚ąß Ioc l u = S }

/-- The family of nonempty bounded half-open intervals `(l, u]` is a ŌÄ-system. -/
lemma isPiSystem_C_Ioc_pi : IsPiSystem C_Ioc_pi := by
  have := isPiSystem_Ioc_mem (univ : Set ‚ĄĚ) univ
  simp only [mem_univ, true_and] at this; exact this

/-- The Borel `ŌÉ`-algebra on `‚ĄĚ` is generated by the family of nonempty bounded half-open
intervals `(l, u]`. -/
lemma generateFrom_C_Ioc_pi :
    generateFrom C_Ioc_pi = (inferInstance : MeasurableSpace ‚ĄĚ) := by
  rw [show (inferInstance : MeasurableSpace ‚ĄĚ) = borel ‚ĄĚ from BorelSpace.measurable_eq]
  exact (borel_eq_generateFrom_Ioc ‚ĄĚ).symm

/-- The family of nonempty bounded half-open intervals `(l, u]` is countably spanning:
e.g. the intervals `(-n-1, n+1]` for `n ‚ąą ‚Ąē` cover `‚ĄĚ`. -/
lemma isCountablySpanning_C_Ioc_pi : IsCountablySpanning C_Ioc_pi := by
  refine ‚ü®fun n => Ioc (-(n : ‚ĄĚ) - 1) (n + 1), ?_, ?_‚ü©
  ¬∑ intro n; exact ‚ü®-(n : ‚ĄĚ) - 1, n + 1, by linarith, rfl‚ü©
  ¬∑ ext x; simp only [mem_iUnion, mem_Ioc, mem_univ, iff_true]
    obtain ‚ü®n, hn‚ü© := exists_nat_gt (|x|)
    exact ‚ü®n, by linarith [neg_abs_le x], by linarith [le_abs_self x]‚ü©

