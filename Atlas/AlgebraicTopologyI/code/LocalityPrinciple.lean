variable (X : TopCat.{0}) (𝒜 : Set (Set X))

/-- The subgroup $S_n^{\mathcal{A}}(X) \subseteq S_n(X)$ of $\mathcal{A}$-small singular
$n$-chains: the subgroup generated by singular simplices whose image is contained in
some member of the family $\mathcal{A}$ (Definition 11.3). -/
def smallChainSubgroup {X : Type*} [TopologicalSpace X] (n : ℕ) (𝒜 : Set (Set X)) :
    AddSubgroup (SingularChains n X) :=
  AddSubgroup.closure
    { c : SingularChains n X |
      ∃ (σ : SingularSimplex n X), IsSmall 𝒜 σ ∧
        c = (FreeAbelianGroup.of σ : FreeAbelianGroup (SingularSimplex n X)) }

/-- The $i$-th face of an $\mathcal{A}$-small simplex is again $\mathcal{A}$-small,
since its image is a subset of the original simplex's image. -/
lemma isSmall_face {n : ℕ} {X : Type*} [TopologicalSpace X] (𝒜 : Set (Set X))
    (σ : SingularSimplex (n + 1) X) (hσ : IsSmall 𝒜 σ)
    (i : Fin (n + 2)) : IsSmall 𝒜 (SingularSimplex.face i σ) := by
  obtain ⟨A, hA, hrange⟩ := hσ
  exact ⟨A, hA, fun x ⟨t, ht⟩ => hrange ⟨faceInclusion n i t, ht⟩⟩

/-- The singular boundary map sends $\mathcal{A}$-small chains to $\mathcal{A}$-small
chains, so the subcomplex $S_*^{\mathcal{A}}(X)$ is closed under $\partial$. -/
lemma boundaryMap_mem_smallChainSubgroup {n : ℕ} {X : Type*} [TopologicalSpace X]
    (𝒜 : Set (Set X))
    (c : SingularChains (n + 1) X)
    (hc : c ∈ smallChainSubgroup (n + 1) 𝒜) :
    boundaryMap n X c ∈ smallChainSubgroup n 𝒜 := by
  have key : smallChainSubgroup (n + 1) 𝒜 ≤
      (smallChainSubgroup n 𝒜).comap (boundaryMap n X) := by
    unfold smallChainSubgroup
    rw [AddSubgroup.closure_le]
    intro x ⟨σ, hσ, hx⟩
    show boundaryMap n X x ∈ smallChainSubgroup n 𝒜
    subst hx
    change (FreeAbelianGroup.lift (fun σ => ∑ i : Fin (n + 2), (-1 : ℤ) ^ (i : ℕ) •
      FreeAbelianGroup.of (SingularSimplex.face i σ))) (FreeAbelianGroup.of σ) ∈ _
    rw [FreeAbelianGroup.lift_apply_of]
    exact sum_mem (fun i _ => (smallChainSubgroup n 𝒜).zsmul_mem
      (AddSubgroup.subset_closure ⟨SingularSimplex.face i σ, isSmall_face 𝒜 σ hσ i, rfl⟩) _)
  exact key hc

/-- The restriction of the singular boundary map to the subcomplex of
$\mathcal{A}$-small chains, giving the differential of $S_*^{\mathcal{A}}(X)$. -/
def smallBoundaryMap {X : Type*} [TopologicalSpace X] (n : ℕ) (𝒜 : Set (Set X)) :
    (smallChainSubgroup (n + 1) 𝒜 : AddSubgroup (SingularChains (n + 1) X)) →+
    (smallChainSubgroup n 𝒜 : AddSubgroup (SingularChains n X)) :=
  ((boundaryMap n X).restrict (smallChainSubgroup (n + 1) 𝒜)).codRestrict
    (smallChainSubgroup n 𝒜)
    (fun ⟨c, hc⟩ => boundaryMap_mem_smallChainSubgroup 𝒜 c hc)

set_option maxHeartbeats 400000 in
/-- The standard cosimplicial identity for face inclusions of the standard simplex:
composing face inclusions in two different orders yields the same map. This is the
combinatorial fact underlying $\partial \circ \partial = 0$. -/
theorem faceInclusion_comp_faceInclusion (n : ℕ)
    (i : Fin (n + 2)) (j : Fin (n + 3)) (hij : (j : ℕ) ≤ (i : ℕ))
    (hj : j.val < n + 2) :
    (faceInclusion (n + 1) i.succ).comp (faceInclusion n (Fin.castLT j hj)) =
    (faceInclusion (n + 1) j).comp (faceInclusion n i) := by
  ext ⟨t, ht⟩ : 1
  simp only [ContinuousMap.comp_apply, faceInclusion]
  apply Subtype.ext
  show Fin.insertNth (α := fun _ => ℝ) i.succ 0 (Fin.insertNth (α := fun _ => ℝ) (Fin.castLT j hj) 0 t) =
       Fin.insertNth (α := fun _ => ℝ) j 0 (Fin.insertNth (α := fun _ => ℝ) i 0 t)
  funext ⟨m, hm⟩
  simp only [Fin.insertNth, Fin.succAboveCases, Fin.succAbove, eq_rec_constant]
  have hi_bound := i.isLt
  have hj_bound := j.isLt
  simp only [Fin.ext_iff, Fin.lt_def, Fin.castLT, Fin.succ,
    Fin.coe_castPred, Fin.val_pred]
  split_ifs <;> first | omega | rfl

/-- The singular boundary maps satisfy $\partial_n \circ \partial_{n+1} = 0$,
making singular chains into a chain complex. -/
theorem boundaryMap_comp_boundaryMap (n : ℕ) (X : Type*) [TopologicalSpace X] :
    (boundaryMap n X).comp (boundaryMap (n + 1) X) = 0 := by sorry

/-- Two consecutive small boundary maps compose to zero, inherited from the
analogous identity on full singular chains. -/
lemma smallBoundaryMap_comp_zero {X : Type*} [TopologicalSpace X]
    (n : ℕ) (𝒜 : Set (Set X)) :
    AddCommGrpCat.ofHom (smallBoundaryMap (X := X) (n + 1) 𝒜) ≫
      AddCommGrpCat.ofHom (smallBoundaryMap (X := X) n 𝒜) = 0 := by
  have h := boundaryMap_comp_boundaryMap n X
  ext ⟨x, hx⟩
  simp only [CategoryTheory.comp_apply, smallBoundaryMap]
  exact DFunLike.congr_fun h x

/-- The chain complex $S_*^{\mathcal{A}}(X)$ of $\mathcal{A}$-small singular chains,
with differentials inherited from the singular chain complex (Definition 11.3). -/
def smallSingularChainComplex (X : TopCat.{0}) (𝒜 : Set (Set X)) :
    ChainComplex AddCommGrpCat ℕ :=
  ChainComplex.of
    (fun n => AddCommGrpCat.of (smallChainSubgroup (X := X) n 𝒜))
    (fun n => AddCommGrpCat.ofHom (smallBoundaryMap (X := X) n 𝒜))
    (fun n => smallBoundaryMap_comp_zero (X := X) n 𝒜)

/-- The canonical isomorphism from `SingularChains n X` (defined as a free abelian
group on singular simplices) into the categorical singular chain complex
`singularChainComplexZ X`, sending each generator to the corresponding coproduct
inclusion of `1 : ℤ`. -/
def singularChainsLift (X : TopCat.{0}) (n : ℕ) :
    SingularChains n X →+
      (singularChainComplexZ X).X n :=
  FreeAbelianGroup.lift (fun (σ : SingularSimplex n X) =>
    (Limits.Sigma.ι (fun _ : (TopCat.toSSet.obj X).obj (Opposite.op (SimplexCategory.mk n)) ↦
      AddCommGrpCat.of ℤ) ((TopCat.toSSetObjEquiv X (Opposite.op (SimplexCategory.mk n))).symm σ)) (1 : ℤ))

/-- The map from $\mathcal{A}$-small chains into the categorical singular chain
complex at degree `n`, defined by first including into all singular chains and then
applying `singularChainsLift`. -/
def smallChainsToChainComplex (X : TopCat.{0}) (𝒜 : Set (Set X)) (n : ℕ) :
    (smallSingularChainComplex X 𝒜).X n ⟶ (singularChainComplexZ X).X n :=
  AddCommGrpCat.ofHom ((singularChainsLift X n).comp (smallChainSubgroup (X := X) n 𝒜).subtype)

/-- The geometric face inclusion of the $n$-simplex into the $(n+1)$-simplex agrees
with the map induced by `Fin.succAbove i` via the standard simplex functor. -/
lemma faceInclusion_eq_stdSimplex_map_succAbove (n : ℕ) (i : Fin (n + 2)) :
    faceInclusion n i =
    ⟨stdSimplex.map (Fin.succAbove i), stdSimplex.continuous_map _⟩ := by
  ext t j
  simp only [faceInclusion, ContinuousMap.coe_mk]
  change Fin.insertNth (α := fun _ => ℝ) i 0 t.1 j =
    (stdSimplex.map (Fin.succAbove i) t).1 j
  change _ = (FunOnFinite.linearMap ℝ ℝ (Fin.succAbove i)) t.1 j
  rw [FunOnFinite.linearMap_apply_apply]
  by_cases hj : j = i
  · subst hj
    rw [Fin.insertNth_apply_same]
    symm
    apply Finset.sum_eq_zero
    intro x hx
    simp only [Finset.mem_filter] at hx
    exact absurd hx.2 (Fin.succAbove_ne _ x)
  · have hj' : ∃ k, i.succAbove k = j :=
      Fin.exists_succAbove_eq hj

    obtain ⟨k, hk⟩ := hj'
    rw [show Fin.insertNth (α := fun _ => ℝ) i 0 t.1 j = t.1 k from by
      conv_lhs => rw [← hk]; rw [Fin.insertNth_apply_succAbove]]
    symm
    have h_filter : Finset.univ.filter (fun x => i.succAbove x = j) = {k} := by
      ext x
      simp only [Finset.mem_filter, Finset.mem_univ, true_and, Finset.mem_singleton]
      exact ⟨fun hx => Fin.succAbove_right_injective (hx.trans hk.symm),
             fun hx => by rw [hx, hk]⟩
    rw [h_filter, Finset.sum_singleton]

