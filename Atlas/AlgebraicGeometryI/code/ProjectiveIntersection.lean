import Atlas.AlgebraicGeometryI.code.DimensionTheory
import Mathlib.RingTheory.KrullDimension.Polynomial
import Mathlib.RingTheory.KrullDimension.Field
import Mathlib.Algebra.MvPolynomial.CommRing
